# Copy this file to .env and fill in real values before running docker compose.

# MTA GTFS-Realtime API key (register at https://api.mta.info/)
MTA_API_KEY=

# Optional: override the MTA feed URL
MTA_FEED_URL=https://api.mta.info/GTFS

# TimescaleDB connection string (default matches docker-compose.yml)
TIMESCALE_DSN=postgresql://pulsecast:pulsecast@timescaledb:5432/pulsecast

# Redis connection URL (default matches docker-compose.yml)
REDIS_URL=redis://redis:6379/0

# Path to exported ONNX model files
ONNX_DIR=/app/models/onnx

# Number of input features for ONNX inference
N_FEATURES=42

# Cache TTL in seconds
CACHE_TTL_SECONDS=300
