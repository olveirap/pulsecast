# Copy this file to .env and fill in real values before running docker compose.

# MTA GTFS-Realtime API key (register at https://api.mta.info/)
MTA_API_KEY=

# MTA Subway feed IDs (comma-separated: GTR,ACE,BDFM,G,JZ,NQRW,L,SIR)
SUBWAY_FEED_IDS=GTR,ACE,BDFM,G,JZ,NQRW,L,SIR

# MTA feed URL pattern – use {feed_id} for per-feed URL substitution
MTA_FEED_URL_PATTERN=https://api.mta.info/GTFS/{feed_id}

# Bus positions S3 bucket (public)
BUS_POSITIONS_BUCKET=nycbuspositions

# Path to subway stop_id -> zone_id mapping CSV
SUBWAY_ZONE_MAP_PATH=/app/pulsecast/data/subway_zone_map.csv

# Path to bus position -> zone_id mapping CSV (if used)
BUS_ZONE_MAP_PATH=/app/pulsecast/data/bus_zone_map.csv

# Strict zone mapping: if TRUE, drop stops that don't map to a zone
STOP_ZONE_MAP_STRICT=TRUE

# TimescaleDB connection string (default matches docker-compose.yml)
TIMESCALE_DSN=postgresql://pulsecast:pulsecast@timescaledb:5432/pulsecast

# Redis connection URL (default matches docker-compose.yml)
REDIS_URL=redis://redis:6379/0

# Path to exported ONNX model files
ONNX_DIR=/app/models/onnx

# Number of input features for ONNX inference
N_FEATURES=43

# Cache TTL in seconds
CACHE_TTL_SECONDS=300
